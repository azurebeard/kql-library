// Name        : Known IOC sweep - hashes + file names (embedded)
// Technique   : n/a (indicator match)
// Tactic      : Indicator matching
// Platform    : Advanced Hunting (unified Microsoft Defender / SecOps portal)
// Data source : DeviceProcessEvents
// Description : Self-contained sweep for known-bad hashes and tool file names.
//               Use when you have no watchlist; otherwise prefer
//               ioc-matching/watchlist-driven-ioc-match.kql.
// Tuning      : File-name matches (e.g. bitsadmin.exe, chrome.exe) also hit
//               legitimate binaries - corroborate with path / hash before acting.
// References  : Spirals ransomware (Symantec, 2026-06)
let spiralsFileNames = dynamic([
    "bitsadmin.exe","vbr2116.exe","revsocks.exe","tunn.exe",
    "cloudflared-windows-amd64.exe","tokens.exe"]);
let spiralsHashes = dynamic([
    "0f9574dc38e5c34a31153f0bcc603c6ec29cb3bf65c3d25380dbe86d42573141",
    "4cab935d0ec400059a3fcdc95b6623efdd51a61dff401fba8d5da244cc2de649",
    "7f0d49b11d0a3697685622ce510c570199bf2dc76515b3f9a6b6735de8c9134b",
    "83a7e51f3787ac5a8a9884edd0a58ddbef380969aa6529d282a461a1a614a892",
    "84b9a9a1668145df04faa3d0e118e2f0acbebd3d9d260baf3a355b44c815c22d",
    "862a3ca7e944ccf0ff3a6d556b34faade4b68343015c35a014a43725ac14a2a1",
    "b5d598b00cc3a28cabc5812d9f762819334614bae452db4e7f23eefe7b081556"]);
DeviceProcessEvents
| where Timestamp > ago(30d)
| where FileName in~ (spiralsFileNames) or SHA256 in (spiralsHashes)
| project Timestamp, DeviceName, AccountName, FileName, FolderPath, SHA256, ProcessCommandLine, InitiatingProcessFileName
